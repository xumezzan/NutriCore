# OpenAI — обязательно для работы сканера и коуча
OPENAI_API_KEY=sk-...

# Telegram Bot Token — обязательно для TMA-валидации в проде
# Получить: @BotFather → /newbot
TELEGRAM_BOT_TOKEN=123456789:AABBCCDDEEFFaabbccddeeff...

# Включить жёсткую проверку initData (рекомендуется в продакшне)
REQUIRE_TMA=true

# Порт (Railway подставит автоматически через $PORT)
PORT=3000
